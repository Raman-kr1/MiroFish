# LLM API configuration (supports any LLM API in OpenAI SDK format)
# Recommended to use Alibaba Cloud Bailian platform qwen-plus model: https://bailian.console.aliyun.com/
# Note that consumption is large, you can try a simulation with less than 40 rounds first
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP Memory Graph Configuration =====
# The monthly free quota is enough for simple use: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Accelerated LLM Configuration (Optional) =====
# Note: If you do not use accelerated configuration, do not include the following configuration items in the env file
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here